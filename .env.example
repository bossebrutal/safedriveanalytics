# Trafikverket API-nyckel (valfritt – lämna tomt för att använda "demokey")
# Registrera gratis nyckel på: https://data.trafikverket.se/documentation/datacache/intro
TRAFIKVERKET_API_KEY=

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=safedriveanalytics
POSTGRES_USER=sda_user
POSTGRES_PASSWORD=change_me_in_production

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://sda_user:change_me_in_production@postgres:5432/safedriveanalytics
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_in_production

# API
API_HOST=0.0.0.0
API_PORT=8000
